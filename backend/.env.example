# ═══════════════════════════════════════════════════
# Treeni AI — Environment Variables
# Copy to .env and fill in your API keys
# ═══════════════════════════════════════════════════

# ── Database (auto-set in docker-compose) ──────────
DATABASE_URL=postgresql+asyncpg://treeni:treeni_secret@localhost:5432/treeni_ai
REDIS_URL=redis://localhost:6379/0

# ── App ────────────────────────────────────────────
ENVIRONMENT=development
SECRET_KEY=change-me-generate-with-secrets.token_hex-32

# Generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-key-here

# ── LLM — REQUIRED ─────────────────────────────────
# https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# ── Contact Sourcing — REQUIRED for live outreach ──
# https://app.apollo.io/#/settings/integrations/api  (free: 50/mo)
APOLLO_API_KEY=your-apollo-key

# https://hunter.io/api-keys  (free: 25/mo)
HUNTER_API_KEY=your-hunter-key

# https://app.zerobounce.net/account-api  ($18 for 2000 verifications)
ZEROBOUNCE_API_KEY=your-zerobounce-key

# ── Email Dispatch — REQUIRED for live outreach ─────
# https://app.sendgrid.com/settings/api_keys
SENDGRID_API_KEY=SG.your-sendgrid-key
SENDGRID_FROM_EMAIL=sustainability@yourdomain.com
SENDGRID_FROM_NAME=Treeni Sustainability

# ── ESG Data Sources ───────────────────────────────
# Internal resustain™ API (if available)
RESUSTAIN_API_BASE=https://api.resustain.com/v2
RESUSTAIN_API_KEY=your-resustain-key

# https://www.cdp.net/en/companies/develop-with-us
CDP_API_KEY=your-cdp-key

# https://serpapi.com/dashboard (for sustainability report search)
SERPAPI_KEY=your-serpapi-key

# ── LinkedIn (optional) ─────────────────────────────
LINKEDIN_ACCESS_TOKEN=your-linkedin-token

# ── WhatsApp (optional) ─────────────────────────────
WHATSAPP_API_TOKEN=your-whatsapp-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id

# ── Feature Flags ───────────────────────────────────
USE_MOCK_ESG_DATA=false
HITL_CONFIDENCE_THRESHOLD=0.75
